# Business Idea Validator - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================
# Required Configuration
# ==============================================================

# Google Gemini API Key
# Get it from: https://makersuite.google.com/app/apikey
API_KEY=your_google_gemini_api_key_here

# ==============================================================
# Optional Configuration
# ==============================================================

# Redis Connection URL (defaults to localhost:6379 if not set)
# Format: redis://[user[:password]@]host[:port][/db]
REDIS_URL=redis://localhost:6379/0

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application Environment (development, staging, production)
ENV=development

# ==============================================================
# Notes
# ==============================================================

# 1. Never commit the .env file - it contains secrets
#    This file (.env.example) shows the template
#
# 2. To get API_KEY:
#    - Go to https://makersuite.google.com/app/apikey
#    - Create a new API key
#    - Copy it to the API_KEY field
#
# 3. Redis is optional:
#    - Without Redis: App works but conversation memory is disabled
#    - With Redis: Conversation context is maintained for 24 hours
#
# 4. Docker users:
#    - Pass environment variables with -e flag
#    - Or create .env file in container
#
# Example running with Docker:
# docker run -e API_KEY=your_key_here -p 8000:8000 business-validator:latest